# =============================================================================
# Environment Configuration for Karakalpak POS+Morph API v1.6
# Tuned for: 4 vCPU / 8 GB RAM (all-in-one: ML API + web server + database)
# =============================================================================
# Copy this file to .env and fill in your values

# Model Configuration
# -------------------
MODEL_DIR=final_model7
LABELS_PATH=label_mappings.pkl
LEMMA_PATH=lemma_dict.pkl
BACKBONE=xlm-roberta-base

# Security Configuration
# ----------------------
# Comma-separated list of allowed origins for CORS
# Use "*" for development; set to your domain in production e.g. https://yoursite.com
ALLOWED_ORIGINS=*

# API Key Authentication
# ----------------------
# Comma-separated list of valid API keys. If empty, auth is DISABLED — WARNING: open access.
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Example: API_KEYS=kaa_abc123def456,kaa_xyz789ghi012
API_KEYS=

# Rate Limiting
# -------------
# Maximum requests per IP address per minute
RATE_LIMIT_PER_MINUTE=30

# Input Limits
# ------------
MAX_SENTENCE_LENGTH=1000
MAX_SENTENCES_PER_REQUEST=50
MAX_TEXT_LENGTH=50000

# Max raw HTTP request body in bytes (10 MB default — DoS protection)
MAX_REQUEST_BODY_BYTES=10485760

# ──────────────────────────────────────────────────────────────────────────────
# Performance — tuned for 4 vCPU / 8 GB RAM
# ──────────────────────────────────────────────────────────────────────────────
#
# Memory budget on 8 GB VPS (all services combined):
#   ML model idle:          ~2.1 GB
#   2 concurrent inferences: ~0.8 GB  (2 × ~400 MB activation tensors)
#   Web server (nginx/app):  ~0.4 GB
#   Database (PostgreSQL):   ~0.5 GB
#   OS + Docker overhead:    ~0.5 GB
#   ─────────────────────────────────
#   Peak total:              ~4.3 GB   ← comfortable within 8 GB
#
# CPU budget on 4 vCPU (at peak inference load):
#   PyTorch: TORCH_THREADS × INFERENCE_CONCURRENCY = 2 × 2 = 4 vCPUs
#   Web/DB share via OS scheduler when inference is idle (which is most of the time)
#
# ──────────────────────────────────────────────────────────────────────────────

# Sentences processed in one forward pass (4 = safe for 8 GB)
# Raise to 8 only if you have ≥10 GB free for the ML container
BATCH_SIZE=4

# Simultaneous inference slots
# 2 = 4-5 concurrent users handled without queuing under normal load
# Drop to 1 if you see OOM errors or run a heavy database on the same VPS
INFERENCE_CONCURRENCY=2

# PyTorch intra-op threads per inference call
# 2 × INFERENCE_CONCURRENCY(2) = 4 vCPUs consumed at peak — matches the 4 vCPU server exactly
TORCH_THREADS=2

# Enable/disable API documentation (/docs, /redoc)
# Recommended: set to false in production to avoid exposing the API schema publicly
ENABLE_DOCS=true

# Server Configuration
# --------------------
# PORT=8000
PYTHONUNBUFFERED=1
