# =============================================================================
# Environment Configuration for Karakalpak POS+Morph API
# =============================================================================
# Copy this file to .env and fill in your values

# Model Configuration
# -------------------
# Directory containing your trained model files
MODEL_DIR=final_model7

# Path to label mappings pickle file
LABELS_PATH=label_mappings.pkl

# Path to lemma dictionary pickle file
LEMMA_PATH=lemma_dict.pkl

# Backbone model name (from HuggingFace)
BACKBONE=xlm-roberta-base

# Security Configuration
# ----------------------
# Comma-separated list of allowed origins for CORS
# Use "*" for development, specific domains for production
# Example: https://yourfrontend.com,https://www.yourfrontend.com
ALLOWED_ORIGINS=*

# Maximum length of a single sentence (in characters)
MAX_SENTENCE_LENGTH=1000

# Maximum number of sentences per request
MAX_SENTENCES_PER_REQUEST=50

# Enable/disable API documentation endpoints (/docs, /redoc)
# Set to "false" in production if you want to hide docs
ENABLE_DOCS=true

# Server Configuration (Railway will set PORT automatically)
# ----------------------------------------------------------
# PORT=8000

# Python Configuration
# --------------------
# Set to production for Railway
PYTHONUNBUFFERED=1
